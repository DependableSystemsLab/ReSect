{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"sourceMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"resolveJsonModule": true,
		"strict": true,
		"noImplicitOverride": true,
		"types": [
			"node",
			"jest"
		]
	}
}