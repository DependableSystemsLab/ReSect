	"version": "0.2.0",
	"configurations": [
		{
			"name": "pnpm: start",
			"request": "launch",
			"preLaunchTask": "pnpm: build",
			"runtimeArgs": [
				"run",
				"start"
			],
			"runtimeExecutable": "pnpm",
			"skipFiles": [
				"<node_internals>/**"
			],
			"type": "node",
			"console": "integratedTerminal"
		}
	]
}